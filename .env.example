# PostgreSQL connection (use SSL params for managed hosts, e.g. ?sslmode=require)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# From @BotFather — used to validate Web App initData and call Bot API (invoices, webhook answers)
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."

# Strong random secret for signing JWTs (min 32 chars recommended)
JWT_SECRET="change-me-to-a-long-random-string"

# Public base URL of this API (no trailing slash). Used in docs / webhook setup, e.g. https://your-app.vercel.app
BASE_URL="https://your-app.vercel.app"

# Optional local dev
# PORT=4000
